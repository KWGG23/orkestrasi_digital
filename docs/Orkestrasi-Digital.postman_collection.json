{
	"info": {
		"_postman_id": "orkestrasi-digital-api-v1",
		"name": "Orkestrasi Digital",
		"description": "API backend untuk sistem Bank Sampah Digital dan Portal Dusun Digital.\n\n**Base URL:** `http://localhost:8000/api/v1`\n\n**Auth:** Endpoint bertanda 🔒 membutuhkan Bearer token. Login dulu via `POST /auth/login`, token akan tersimpan otomatis ke variable `{{token}}`.\n\n**Response format:**\n```json\n{ \"success\": true, \"message\": \"OK\", \"data\": {...}, \"meta\": {...} }\n```\n\n**Kontak BE:** vincentius.erwan23@gmail.com",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "🔐 Auth",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Login admin. Token disimpan otomatis ke `{{token}}` via test script.",
						"auth": {
							"type": "noauth"
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@desadijital.id\",\n  \"password\": \"password\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains token', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.true;",
									"    pm.expect(json.data.token).to.be.a('string').and.not.empty;",
									"    pm.expect(json.data.token_type).to.eql('Bearer');",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.data.token);",
									"    console.log('Token tersimpan:', json.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Login - Password Salah (negative)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Uji negatif: kredensial salah harus ditolak 401, bukan 500 atau 200.",
						"auth": {
							"type": "noauth"
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@desadijital.id\",\n  \"password\": \"password-salah-sengaja\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 401', function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test('Response has success:false envelope', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.success).to.be.false;",
									"});",
									"",
									"pm.test('Error message is informative', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json.message).to.include('salah');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
