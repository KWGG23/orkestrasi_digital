# Nilai di bawah aman untuk local dev. Di Railway/production WAJIB:
# APP_ENV=production, APP_DEBUG=false -- APP_DEBUG=true di production akan
# menampilkan stack trace lengkap (path server, query, env var) ke publik
# kalau ada error.
APP_NAME="Desa Digital Karangasem"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev: MySQL. Railway/production: Postgres dari Supabase --
# ganti DB_CONNECTION=pgsql dan isi host/port/database/username/password
# dari Supabase dashboard > Project Settings > Database. Supabase Postgres
# butuh SSL, DB_SSLMODE=require kalau connection ke Supabase ditolak.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=desa_digital
DB_USERNAME=root
DB_PASSWORD=
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Storage untuk disk 'public' (foto UMKM, GeoJSON) -- default 'local' aman
# untuk dev, tapi di Railway/production WAJIB 's3' karena filesystem Railway
# ephemeral (hilang tiap redeploy). Kalau 's3', isi kredensial S3-compatible
# di bawah (mis. Supabase Storage: cek project settings > Storage > S3 access keys).
FILESYSTEM_PUBLIC_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# CORS (config/cors.php) baca ini -- di production WAJIB diganti ke domain
# Vercel asli, kalau tidak semua request dari frontend bakal kena CORS block.
FRONTEND_URL=http://localhost:5173

# AdminSeeder: wajib diisi kalau APP_ENV bukan local/testing (staging/production).
# Kosongkan di local/testing untuk pakai default dev "password". Dua akun
# terpisah dengan role berbeda -- admin bank sampah cuma bisa akses fitur
# setoran/tabungan/laporan, admin desa cuma bisa akses UMKM/profil dusun/
# pengumuman (lihat App\Models\User::ROLES dan role:... di routes/api.php).
ADMIN_DEFAULT_EMAIL=admin@desadijital.id
ADMIN_DEFAULT_PASSWORD=

ADMIN_DESA_EMAIL=admindesa@desadijital.id
ADMIN_DESA_PASSWORD=
